# OpenProject connection.
# Recommended (no Tailscale hairpin): the internal Docker address on the shared
# backend network, e.g. http://web:8080  (the same path hocuspocus uses).
# If authenticated writes fail under OPENPROJECT_HTTPS=true, fall back to the
# external https URL. See the design doc's manual write-test (§B).
OPENPROJECT_URL=http://web:8080
OPENPROJECT_API_KEY=your_api_key_here

# MCP bearer auth (shared secret between this server and Claude Desktop / clients)
MCP_AUTH_TOKEN=change_me_to_a_long_random_secret

# Tailscale
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxx

# Auth policy
MCP_REQUIRE_BEARER=true
# Comma-separated Tailscale login emails allowed to call MCP; empty = any authenticated Tailscale identity
MCP_ALLOWED_LOGINS=

# Port the HTTP server listens on (loopback inside the container / Tailscale namespace)
MCP_PORT=8091

# DNS-rebinding allowlist. CRITICAL: MCP_ALLOWED_HOSTS must include the Tailscale
# MagicDNS hostname this node is served on (sidecar hostname is "openproject-mcp",
# so it is openproject-mcp.<your-tailnet>.ts.net). Omit it and every request gets
# a 421 "Misdirected Request" from the DNS-rebinding guard. Keep loopback too.
# (If unsure whether `tailscale serve` forwards the public Host or rewrites it to
# localhost, listing both — as below — is safe; trim after the manual check.)
MCP_ALLOWED_HOSTS=openproject-mcp.your-tailnet.ts.net,127.0.0.1,localhost
MCP_ALLOWED_ORIGINS=https://openproject-mcp.your-tailnet.ts.net
